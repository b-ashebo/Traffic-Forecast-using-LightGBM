print("Saved: fig1_actual_vs_predicted.png / .pdf")


#Scatter — Actual vs Predicted 
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(7.2, 3.4))

for ax, actual, pred, color, unit, label in [
    (ax1, y_test_s.values, pred_speed, COLORS["teal"],   "mph", "(a)"),
    (ax2, y_test_t.values, pred_tti,   COLORS["purple"], "TTI", "(b)"),
]:
    ax.scatter(actual, pred, s=2, alpha=0.10, color=color, edgecolors="none", rasterized=True)

    lo = min(actual.min(), pred.min())
    hi = max(actual.max(), pred.max())
    pad = (hi - lo) * 0.04
    lims = [lo - pad, hi + pad]
    ax.plot(lims, lims, ls="--", lw=1.0, color=COLORS["red"], alpha=0.55)

    slope, intercept, r_val, _, _ = stats.linregress(actual, pred)
    fit_x = np.linspace(lims[0], lims[1], 100)
    ax.plot(fit_x, slope * fit_x + intercept,
            color=COLORS["amber"], lw=1.0, alpha=0.7)

    r2 = r_val ** 2
    ax.text(0.06, 0.90, f"$R^2 = {r2:.4f}$",
            transform=ax.transAxes, fontsize=9, color=COLORS["text"],
            bbox=dict(boxstyle="round,pad=0.3", fc=COLORS["bg"],
                      ec=COLORS["grid"], lw=0.5))

    ax.set_xlim(lims)
    ax.set_ylim(lims)
    ax.set_aspect("equal")
    _style(ax, xlabel=f"Actual ({unit})", ylabel=f"Predicted ({unit})", label=label)

plt.tight_layout()
plt.savefig("fig2_scatter_calibration.png")
plt.savefig("fig2_scatter_calibration.pdf")
plt.show()
print("Saved: fig2_scatter_calibration.png / .pdf")


#Figure 3: Feature Importance — Lollipop
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(7.2, 4.0))

for ax, model, color, color_lt, label in [
    (ax1, model_speed, COLORS["teal"],   COLORS["teal_lt"],   "(a)"),
    (ax2, model_tti,   COLORS["purple"], COLORS["purple_lt"], "(b)"),
]:
    imp = pd.Series(model.feature_importances_,
                     index=feature_cols).sort_values().tail(15)
    yp = np.arange(len(imp))

    ax.hlines(yp, 0, imp.values, color=color_lt, lw=2.0, zorder=2)
    ax.scatter(imp.values, yp, color=color, s=36,
               edgecolors="white", linewidths=0.8, zorder=3)

    ax.set_yticks(yp)
    ax.set_yticklabels(imp.index, fontsize=7.5)
    ax.set_xlim(left=0)
    _style(ax, xlabel="Importance (gain)", label=label)

plt.tight_layout()
plt.savefig("fig3_feature_importance.png")
plt.savefig("fig3_feature_importance.pdf")
plt.show()
print("Saved: fig3_feature_importance.png / .pdf")


#Figure 4: Error Distribution — KDE + Rug 
fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(7.2, 3.2))

for ax, err, color, color_lt, unit, label in [
    (ax1, err_speed, COLORS["coral"],  COLORS["coral_lt"],  "mph", "(a)"),
    (ax2, err_tti,   COLORS["purple"], COLORS["purple_lt"], "TTI", "(b)"),
]:
    kde_x = np.linspace(err.min() - 1, err.max() + 1, 500)
    kde   = stats.gaussian_kde(err)

    ax.fill_between(kde_x, kde(kde_x), alpha=0.18, color=color_lt, lw=0)
    ax.plot(kde_x, kde(kde_x), color=color, lw=1.4)

    # Rug
    ax.plot(err, np.full_like(err, -0.003 * kde(kde_x).max()),
            "|", color=color, alpha=0.06, markersize=5)

    ax.axvline(0, color=COLORS["text_light"], lw=0.7, alpha=0.4)
    ax.axvline(np.mean(err), color=COLORS["red"],   ls="--", lw=1.0,
               label=f"Mean = {np.mean(err):+.3f}")
    ax.axvline(np.median(err), color=COLORS["amber"], ls=":", lw=1.0,
               label=f"Median = {np.median(err):+.3f}")

    _style(ax, xlabel=f"Error ({unit})", ylabel="Density", label=label)
    _legend(ax, loc="upper left", fontsize=7)

plt.tight_layout()
plt.savefig("fig4_error_distribution.png")
plt.savefig("fig4_error_distribution.pdf")
plt.show()
print("Saved: fig4_error_distribution.png / .pdf")


#Figure 5: Error by Hour of Day — Box Plot 
hours = test_df["hour"].values
hour_groups_s = [err_speed[hours == h] for h in range(24)]
hour_groups_t = [err_tti[hours == h]   for h in range(24)]

fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(7.2, 4.6), sharex=True)

def _box(ax, groups, fill, edge, med_col, ylabel, label):
    bp = ax.boxplot(
        groups, positions=range(24), widths=0.55,
        patch_artist=True, showfliers=False,
        medianprops  = dict(color=med_col, lw=1.5),
        whiskerprops = dict(color=COLORS["text_light"], lw=0.6),
        capprops     = dict(color=COLORS["text_light"], lw=0.6),
    )
    for p in bp["boxes"]:
        p.set_facecolor(fill)
        p.set_edgecolor(edge)
        p.set_alpha(0.45)
        p.set_linewidth(0.6)
    ax.axhline(0, color=COLORS["text_light"], lw=0.7, alpha=0.35)
    # Rush-hour bands
    for s, e in [(7, 9), (16, 18)]:
        ax.axvspan(s - 0.5, e + 0.5, alpha=0.05, color=COLORS["amber"], zorder=0)
    _style(ax, ylabel=ylabel, label=label)

_box(ax1, hour_groups_s, COLORS["teal_lt"], COLORS["teal"],
     COLORS["coral"], "Speed error (mph)", "(a)")
_box(ax2, hour_groups_t, COLORS["purple_lt"], COLORS["purple"],
     COLORS["amber"], "TTI error", "(b)")

ax2.set_xticks(range(24))
ax2.set_xticklabels([f"{h:02d}" for h in range(24)], fontsize=7)
_style(ax2, xlabel="Hour of day")

plt.tight_layout()
plt.savefig("fig5_error_by_hour.png")
plt.savefig("fig5_error_by_hour.pdf")
