def _style(ax, xlabel=None, ylabel=None, label=None):
    """Apply journal styling + optional (a)/(b) panel label."""
    if xlabel:
        ax.set_xlabel(xlabel, labelpad=6)
    if ylabel:
        ax.set_ylabel(ylabel, labelpad=6)
    ax.tick_params(axis="both", length=3, width=0.5)
    for sp in ax.spines.values():
        sp.set_color(COLORS["grid"])
    if label:
        ax.text(
            -0.02, 1.06, label,
            transform=ax.transAxes, fontsize=11,
            fontweight="bold", color=COLORS["text"], va="bottom", ha="right",
        )


def _legend(ax, **kw):
    defaults = dict(
        frameon=True, facecolor=COLORS["bg"],
        edgecolor=COLORS["grid"], borderpad=0.5,
        handlelength=1.6, handletextpad=0.5,
    )
    defaults.update(kw)
    ax.legend(**defaults)



#LOAD DATA
df = pd.read_parquet("outputs/phase2_master_dataset/master_dataset.parquet")
print(f"Loaded: {df.shape[0]:,} rows × {df.shape[1]} cols")
print(f"Date range: {df['timestamp'].min()} → {df['timestamp'].max()}")



# Temporal feature extraction
df = df.copy()
df["timestamp"] = pd.to_datetime(df["timestamp"])

df["hour"]         = df["timestamp"].dt.hour
df["minute"]       = df["timestamp"].dt.minute
df["day_of_week"]  = df["timestamp"].dt.dayofweek
df["day_of_month"] = df["timestamp"].dt.day
df["month"]        = df["timestamp"].dt.month
df["is_weekend"]   = (df["day_of_week"] >= 5).astype(int)

df["hour_sin"] = np.sin(2 * np.pi * df["hour"] / 24)
df["hour_cos"] = np.cos(2 * np.pi * df["hour"] / 24)
df["dow_sin"]  = np.sin(2 * np.pi * df["day_of_week"] / 7)
df["dow_cos"]  = np.cos(2 * np.pi * df["day_of_week"] / 7)

# Encode categoricals
label_encoders = {}
categorical_cols = ["tmc_code", "direction", "county"]
for col in categorical_cols:
    le = LabelEncoder()
    df[col] = le.fit_transform(df[col].astype(str))
    label_encoders[col] = le
    print(f"  Encoded '{col}': {len(le.classes_)} classes")

# Handle missing values
missing = df.isnull().sum().sum()
if missing > 0:
    num_cols = df.select_dtypes(include=[np.number]).columns
    df[num_cols] = df[num_cols].ffill().bfill()
    print(f"  Filled {missing} missing values (forward/backward fill)")

print(f"  Final shape: {df.shape}")

#FEATURE / TARGET SPLIT
target_cols = ["target_speed", "target_tti"]
drop_cols   = ["timestamp"]
feature_cols = [c for c in df.columns if c not in target_cols + drop_cols]
cat_feature_names = [c for c in categorical_cols if c in feature_cols]

print(f"\nFeatures : {len(feature_cols)}")
print(f"Targets  : {target_cols}")

#CHRONOLOGICAL TRAIN / VAL / TEST SPLIT 

df = df.sort_values("timestamp").reset_index(drop=True)
n = len(df)
i_train = int(n * 0.70)
i_val   = int(n * 0.85)

train_df = df.iloc[:i_train]
val_df   = df.iloc[i_train:i_val]
test_df  = df.iloc[i_val:]

X_train, X_val, X_test = train_df[feature_cols], val_df[feature_cols], test_df[feature_cols]
y_train_s, y_val_s, y_test_s = train_df["target_speed"], val_df["target_speed"], test_df["target_speed"]
y_train_t, y_val_t, y_test_t = train_df["target_tti"],   val_df["target_tti"],   test_df["target_tti"]

print(f"\nTrain : {len(train_df):>8,} rows   {df['timestamp'].iloc[0].date()} → {df['timestamp'].iloc[i_train-1].date()}")
print(f"Val   : {len(val_df):>8,} rows   {df['timestamp'].iloc[i_train].date()} → {df['timestamp'].iloc[i_val-1].date()}")
print(f"Test  : {len(test_df):>8,} rows   {df['timestamp'].iloc[i_val].date()} → {df['timestamp'].iloc[-1].date()}")


# LIGHTGBM TRAINING

params = {
    "objective":        "regression",
    "metric":           "mae",
    "boosting_type":    "gbdt",
    "num_leaves":       63,
    "learning_rate":    0.05,
    "n_estimators":     2000,
    "min_child_samples": 20,
    "subsample":        0.8,
    "colsample_bytree": 0.8,
    "reg_alpha":        0.1,
    "reg_lambda":       1.0,
    "random_state":     42,
    "n_jobs":           -1,
    "verbose":          -1,
}

cb = [lgb.early_stopping(50, verbose=True), lgb.log_evaluation(200)]

#Speed model 
print("\n" + "=" * 60)
print("  Training: target_speed")
print("=" * 60)
model_speed = lgb.LGBMRegressor(**params)
model_speed.fit(X_train, y_train_s,
                eval_set=[(X_val, y_val_s)], eval_metric="mae",
                callbacks=cb, categorical_feature=cat_feature_names)
print(f"  Best iter: {model_speed.best_iteration_}")

#TTI model
print("\n" + "=" * 60)
print("  Training: target_tti")
print("=" * 60)
model_tti = lgb.LGBMRegressor(**params)
model_tti.fit(X_train, y_train_t,
              eval_set=[(X_val, y_val_t)], eval_metric="mae",
              callbacks=cb, categorical_feature=cat_feature_names)
print(f"  Best iter: {model_tti.best_iteration_}")

#EVALUATION
pred_speed = model_speed.predict(X_test)
pred_tti   = model_tti.predict(X_test)

err_speed = y_test_s.values - pred_speed
err_tti   = y_test_t.values - pred_tti


def metrics(y, yhat):
    return {
        "MAE":  mean_absolute_error(y, yhat),
        "RMSE": np.sqrt(mean_squared_error(y, yhat)),
        "MAPE": mean_absolute_percentage_error(y, yhat) * 100,
        "R2":   r2_score(y, yhat),
    }


m_speed = metrics(y_test_s, pred_speed)
m_tti   = metrics(y_test_t, pred_tti)

print("\n" + "=" * 60)
print(f"  Speed — MAE: {m_speed['MAE']:.4f}  RMSE: {m_speed['RMSE']:.4f}  "
      f"MAPE: {m_speed['MAPE']:.2f}%  R²: {m_speed['R2']:.4f}")
print(f"  TTI   — MAE: {m_tti['MAE']:.4f}  RMSE: {m_tti['RMSE']:.4f}  "
      f"MAPE: {m_tti['MAPE']:.2f}%  R²: {m_tti['R2']:.4f}")
print("=" * 60)

#Cross-validation
print("\nRunning 5-fold TimeSeriesSplit CV …")
X_cv = pd.concat([X_train, X_val])
y_cv_s = pd.concat([y_train_s, y_val_s])
y_cv_t = pd.concat([y_train_t, y_val_t])

cv_s, cv_t = [], []
for fold, (ti, vi) in enumerate(TimeSeriesSplit(n_splits=5).split(X_cv), 1):
    Xtr, Xvl = X_cv.iloc[ti], X_cv.iloc[vi]

    ms = lgb.LGBMRegressor(**params)
    ms.fit(Xtr, y_cv_s.iloc[ti], eval_set=[(Xvl, y_cv_s.iloc[vi])],
           callbacks=[lgb.early_stopping(50, verbose=False), lgb.log_evaluation(0)],
           categorical_feature=cat_feature_names)
    cv_s.append(mean_absolute_error(y_cv_s.iloc[vi], ms.predict(Xvl)))

    mt = lgb.LGBMRegressor(**params)
    mt.fit(Xtr, y_cv_t.iloc[ti], eval_set=[(Xvl, y_cv_t.iloc[vi])],
           callbacks=[lgb.early_stopping(50, verbose=False), lgb.log_evaluation(0)],
           categorical_feature=cat_feature_names)
    cv_t.append(mean_absolute_error(y_cv_t.iloc[vi], mt.predict(Xvl)))

    print(f"  Fold {fold}:  Speed MAE = {cv_s[-1]:.4f}  |  TTI MAE = {cv_t[-1]:.4f}")

print(f"\n  CV Speed MAE: {np.mean(cv_s):.4f} ± {np.std(cv_s):.4f}")
print(f"  CV TTI   MAE: {np.mean(cv_t):.4f} ± {np.std(cv_t):.4f}")

#Save artefacts 
model_speed.booster_.save_model("model_speed_lgbm.txt")
model_tti.booster_.save_model("model_tti_lgbm.txt")

results = test_df[["timestamp", "tmc_code"]].copy()
results["actual_speed"]    = y_test_s.values
results["predicted_speed"] = pred_speed
results["actual_tti"]      = y_test_t.values
results["predicted_tti"]   = pred_tti
results.to_csv("test_predictions.csv", index=False)
print("\nSaved: model_speed_lgbm.txt, model_tti_lgbm.txt, test_predictions.csv")



#  Figure 1: Actual vs Predicted — Time Series 
window = min(192, len(test_df))
ts   = test_df["timestamp"].values[:window]
a_s  = y_test_s.values[:window]
p_s  = pred_speed[:window]
a_t  = y_test_t.values[:window]
p_t  = pred_tti[:window]

fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(7.2, 4.2), sharex=True)

ax1.fill_between(ts, a_s, p_s, alpha=0.10, color=COLORS["coral"], lw=0)
ax1.plot(ts, a_s, color=COLORS["teal"],  lw=1.3, label="Actual")
ax1.plot(ts, p_s, color=COLORS["coral"], lw=1.0, ls="--", alpha=0.85, label="Predicted")
_style(ax1, ylabel="Speed (mph)", label="(a)")
_legend(ax1, loc="upper right")

ax2.fill_between(ts, a_t, p_t, alpha=0.10, color=COLORS["purple"], lw=0)
ax2.plot(ts, a_t, color=COLORS["teal"],   lw=1.3, label="Actual")
ax2.plot(ts, p_t, color=COLORS["purple"], lw=1.0, ls="--", alpha=0.85, label="Predicted")
_style(ax2, xlabel="Time", ylabel="TTI", label="(b)")
_legend(ax2, loc="upper right")

fig.autofmt_xdate(rotation=30, ha="right")
plt.tight_layout()
plt.savefig("fig1_actual_vs_predicted.png")
plt.savefig("fig1_actual_vs_predicted.pdf")
